{
  "name": "veloracss",
  "version": "1.0.1",
  "description": "AI-designed utility-first CSS framework with Color Genetics, Container Intelligence, and zero-JS State Machines",
  "keywords": [
    "css",
    "framework",
    "utility-first",
    "css-framework",
    "design-system",
    "oklch",
    "container-queries"
  ],
  "license": "MIT",
  "author": "VeloraX",
  "homepage": "https://velorax.github.io/veloracss/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VeloraX/veloracss.git"
  },
  "bugs": {
    "url": "https://github.com/VeloraX/veloracss/issues"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "main": "dist/velora.css",
  "exports": {
    ".": "./dist/velora.css",
    "./min": "./dist/velora.min.css",
    "./src": "./src/velora.css"
  },
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "playground": "node build.mjs && vite",
    "playground:build": "node build.mjs && vite build",
    "demo": "node build.mjs && cd nextjs-demo && npm run dev",
    "demo:build": "node build.mjs && cd nextjs-demo && npm run build",
    "dev": "node build.mjs && vite"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@types/lz-string": "^1.3.34",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "lz-string": "^1.5.0"
  }
}
